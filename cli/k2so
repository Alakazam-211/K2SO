cmd_state() {
    local subcmd="${1:-}"
    case "$subcmd" in
        list)
            cli_request "/cli/states/list" | python3 -c "
import json, sys
states = json.loads(sys.stdin.read())
if not states:
    print('No workspace states defined.')
    sys.exit(0)
for s in states:
    built_in = ' [DEFAULT]' if s.get('isBuiltIn') else ''
    hb = 'on' if s.get('heartbeat') else 'off'
    print(f\"  {s['name']}{built_in} (heartbeat: {hb})\")
    caps = []
    for k, label in [('capFeatures','Features'),('capIssues','Issues'),('capCrashes','Crashes'),('capSecurity','Security'),('capAudits','Audits')]:
        caps.append(f'{label}:{s.get(k,\"off\")}')
    print(f'    {\"  \".join(caps)}')
    if s.get('description'):
        print(f'    {s[\"description\"]}')
" 2>/dev/null
            ;;
        get)
            shift
            local id="${1:-}"
            if [ -z "$id" ]; then
                echo "Usage: k2so state get <state-id>" >&2
                exit 1
            fi
            cli_request "/cli/states/get" "id=$(urlencode "$id")"
            ;;
        set)
            shift
            local state_id=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --state) state_id="$2"; shift 2 ;;
                    *) [ -z "$state_id" ] && state_id="$1"; shift ;;
                esac
            done
            if [ -z "$state_id" ]; then
                echo "Usage: k2so state set <state-id>" >&2
                echo "  Assign a workspace state to the current project." >&2
                echo "  Use 'k2so state list' to see available states." >&2
                exit 1
            fi
            cli_request "/cli/states/set" "state_id=$(urlencode "$state_id")"
            echo "Workspace state set to: $state_id"
            ;;
        *)
            echo "Usage: k2so state <list|get|set>" >&2
            exit 1
            ;;
    esac
}

