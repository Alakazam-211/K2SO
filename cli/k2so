            --cwd) cwd="$2"; shift 2 ;;
            --wait) wait="1"; shift ;;
            *) shift ;;
        esac
    done
    if [ -z "$command" ]; then
        echo "Usage: k2so terminal spawn --command \"...\" [--title \"...\"] [--agent <name>] [--wait]" >&2
        exit 1
