cmd_delegate() {
    local target="${1:-}" file="${2:-}"
    if [ -z "$target" ] || [ -z "$file" ]; then
        echo "Usage: k2so delegate <target-agent> <work-file-path>" >&2
        echo "" >&2
        echo "This single command does everything:" >&2
        echo "  - Creates a git worktree for the agent" >&2
        echo "  - Writes a CLAUDE.md with task context" >&2
        echo "  - Moves the work item to active/" >&2
        echo "  - Launches the agent's Claude session" >&2
        exit 1
    fi
    # Resolve relative paths to absolute
    if [ "${file:0:1}" != "/" ]; then
        file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"
    fi
    echo "Delegating to $target..."
    RESULT=$(cli_request "/cli/agents/delegate" "target=$(urlencode "$target")&file=$(urlencode "$file")")
    BRANCH=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('branch',''))" 2>/dev/null)
    WT=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('worktreePath',''))" 2>/dev/null)
    if [ -n "$BRANCH" ]; then
        echo "  Agent: $target"
        echo "  Branch: $BRANCH"
        echo "  Worktree: $WT"
        echo "  Claude session launching..."
    else
        echo "$RESULT"
    fi
}

