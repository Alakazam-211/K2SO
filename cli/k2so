#!/bin/bash
# K2SO CLI — Agent interface to K2SO workspace orchestration
# This script communicates with K2SO's running instance via HTTP.
# Works inside K2SO terminals (auto-configured) and external terminals
# (auto-discovers connection from ~/.k2so/heartbeat.{port,token}).

K2SO_CLI_VERSION="0.24.10"

set -euo pipefail

# Connection details (set by K2SO when creating terminal sessions)
# Falls back to ~/.k2so/heartbeat.{port,token} for external terminals
PORT="${K2SO_PORT:-}"
TOKEN="${K2SO_HOOK_TOKEN:-}"

# Resolve project root: if K2SO_PROJECT_PATH is set, use it directly.
# Otherwise walk up from CWD to find a .k2so/ directory, skipping $HOME/.k2so.
# Also handles git worktrees: if CWD is inside a worktree, resolve back to
# the main repo root where .k2so/ lives.
PROJECT="${K2SO_PROJECT_PATH:-$(pwd)}"
if [ -z "${K2SO_PROJECT_PATH:-}" ]; then
    _dir="$(pwd)"
    _found=""
    while [ "$_dir" != "/" ]; do
        if [ -d "$_dir/.k2so" ] && [ "$_dir" != "$HOME" ]; then
            _found="$_dir"
            break
        fi
        _dir="$(dirname "$_dir")"
    done
    if [ -z "$_found" ]; then
        # May be inside a git worktree — resolve to main repo root
        _main_root=$(git -C "$(pwd)" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/.git$||')
        if [ -n "$_main_root" ] && [ -d "$_main_root/.k2so" ]; then
            _found="$_main_root"
        fi
    fi
    PROJECT="${_found:-$PROJECT}"
    unset _dir _found _main_root
fi

# Auto-discover connection from ~/.k2so/ if not in a K2SO terminal
if [ -z "$PORT" ] || [ -z "$TOKEN" ]; then
    K2SO_HOME="${HOME}/.k2so"
    if [ -f "${K2SO_HOME}/heartbeat.port" ] && [ -f "${K2SO_HOME}/heartbeat.token" ]; then
        PORT="${PORT:-$(cat "${K2SO_HOME}/heartbeat.port" 2>/dev/null)}"
        TOKEN="${TOKEN:-$(cat "${K2SO_HOME}/heartbeat.token" 2>/dev/null)}"
    fi
fi

if [ -z "$PORT" ] || [ -z "$TOKEN" ]; then
    echo "Error: Cannot connect to K2SO." >&2
    echo "Either run this from a K2SO terminal, or ensure K2SO is running." >&2
    echo "(Connection details: ~/.k2so/heartbeat.port and ~/.k2so/heartbeat.token)" >&2
    exit 1
fi

BASE_URL="http://127.0.0.1:${PORT}"

# HTTP helper
cli_request() {
    local endpoint="$1"
    shift
    local params="token=${TOKEN}&project=$(urlencode "$PROJECT")"
    for param in "$@"; do
        params="${params}&${param}"
    done
    curl -sG "${BASE_URL}${endpoint}" \
        --connect-timeout 5 --max-time 30 \
        -d "$params" 2>/dev/null
}

urlencode() {
    python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1" 2>/dev/null || echo "$1"
}

# Format JSON output for terminal
format_agents() {
    python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
if not data:
    print('No agents found.')
    sys.exit(0)
for a in data:
    inbox = a.get('inboxCount', 0)
    active = a.get('activeCount', 0)
    done = a.get('doneCount', 0)
    role = a.get('role', '')
    name = a.get('name', '')
    status = f'inbox:{inbox} active:{active} done:{done}'
    print(f'  {name:<20} {role:<30} [{status}]')
" 2>/dev/null || cat
}

format_work() {
    python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
if not data:
    print('No work items found.')
    sys.exit(0)
for item in data:
    folder = item.get('folder', '?')
    priority = item.get('priority', 'normal')
    title = item.get('title', item.get('filename', ''))
    prio_mark = {'high': '!', 'critical': '!!', 'normal': ' ', 'low': '.'}
    mark = prio_mark.get(priority, ' ')
    print(f'  [{folder:<6}] {mark} {title}')
" 2>/dev/null || cat
}

