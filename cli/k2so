" 2>/dev/null
            ;;
        schedule)
            # Project-level schedule management
            # k2so heartbeat schedule              → show current schedule
            # k2so heartbeat schedule off          → disable schedule
            # k2so heartbeat schedule hourly --start 09:00 --end 17:00 --every 30 --unit minutes
            # k2so heartbeat schedule daily --time 09:00
            # k2so heartbeat schedule weekly --days mon,wed,fri --time 09:00
            # k2so heartbeat schedule monthly --days 1,15 --time 09:00
            # k2so heartbeat schedule yearly --months jan,jul --time 09:00
            shift
            local sched_mode="${1:-}"
            if [ -z "$sched_mode" ]; then
                # Show current schedule
                cli_request "/cli/heartbeat/schedule" | python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    mode = d.get('mode', 'off')
    schedule = d.get('schedule')
    last_fire = d.get('lastFire', '')
    print(f'Heartbeat schedule:')
    print(f'  Mode: {mode}')
    if mode == 'off':
        print('  (disabled)')
    elif schedule:
        s = json.loads(schedule) if isinstance(schedule, str) else schedule
        if mode == 'hourly':
            secs = s.get('every_seconds', 300)
            freq = f'{secs // 3600}h' if secs >= 3600 else f'{secs // 60}m'
            print(f'  Window:    {s.get(\"start\", \"00:00\")} – {s.get(\"end\", \"23:59\")}')
            print(f'  Frequency: every {freq}')
        else:
            freq = s.get('frequency', '?')
            print(f'  Frequency: {freq}')
            print(f'  Time:      {s.get(\"time\", \"?\")}')
            if freq == 'weekly':
                print(f'  Days:      {\", \".join(s.get(\"days\", []))}')
            elif freq == 'monthly':
                dom = s.get('days_of_month', [])
                if dom:
