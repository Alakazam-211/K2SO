                [ -n "$months" ] && echo "  Months: ${months}"
            fi
            ;;
        *)
            # No on/off/set/get → trigger triage (original behavior)
            echo "Triggering heartbeat triage..."
            cli_request "/cli/heartbeat"
            ;;
    esac
}

