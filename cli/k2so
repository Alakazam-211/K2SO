cmd_done() {
    local agent="${K2SO_AGENT_NAME:-}"
    local blocked=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent="$2"; shift 2 ;;
            --blocked) blocked="$2"; shift 2 ;;
            *) shift ;;
        esac
