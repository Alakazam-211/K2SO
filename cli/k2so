cmd_terminal_spawn() {
    local agent="" command="" title="" wait="" cwd=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --title) title="$2"; shift 2 ;;
            --command) command="$2"; shift 2 ;;
            --agent) agent="$2"; shift 2 ;;
            --cwd) cwd="$2"; shift 2 ;;
            --wait) wait="1"; shift ;;
            *) shift ;;
        esac
    done
    if [ -z "$command" ]; then
        echo "Usage: k2so terminal spawn --command \"...\" [--title \"...\"] [--agent <name>] [--wait]" >&2
        exit 1
    fi
    local params="command=$(urlencode "$command")"
    [ -n "$title" ] && params="${params}&title=$(urlencode "$title")"
    [ -n "$agent" ] && params="${params}&agent=$(urlencode "$agent")"
    [ -n "$cwd" ] && params="${params}&cwd=$(urlencode "$cwd")"
    [ -n "$wait" ] && params="${params}&wait=1"
    cli_request "/cli/terminal/spawn" "$params"
    echo "Terminal spawned: ${title:-$command}"
}

cmd_work_create() {
    local agent="" title="" body="" priority="" item_type="" source="" body_file=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --agent) agent="$2"; shift 2 ;;
            --title) title="$2"; shift 2 ;;
            --body) body="$2"; shift 2 ;;
            --body-file) body_file="$2"; shift 2 ;;
            --priority) priority="$2"; shift 2 ;;
            --type) item_type="$2"; shift 2 ;;
            --source) source="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    # --body-file reads body from a file (avoids shell quoting issues with special chars)
    if [ -n "$body_file" ]; then
        if [ ! -f "$body_file" ]; then
            echo "Error: body file not found: $body_file" >&2
            exit 1
        fi
        body=$(cat "$body_file")
    fi
    if [ -z "$title" ]; then
        echo "Usage: k2so work create --title \"...\" [--body \"...\"|--body-file <path>] [--agent <name>] [--priority high|normal|low]" >&2
        exit 1
    fi
    local params="title=$(urlencode "$title")&body=$(urlencode "$body")"
    [ -n "$agent" ] && params="${params}&agent=$(urlencode "$agent")"
    [ -n "$priority" ] && params="${params}&priority=$(urlencode "$priority")"
    [ -n "$item_type" ] && params="${params}&type=$(urlencode "$item_type")"
    [ -n "$source" ] && params="${params}&source=$(urlencode "$source")"
    cli_request "/cli/agents/work/create" "$params"
}

cmd_agentic() {
    local action="${1:-}"
    case "$action" in
        on|enable|1|true)
            cli_request "/cli/agentic" "enable=on"
            echo "Agentic Systems enabled."
            ;;
        off|disable|0|false)
            cli_request "/cli/agentic" "enable=off"
            echo "Agentic Systems disabled."
            ;;
        *)
            cli_request "/cli/agentic" | python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
enabled = d.get('agenticEnabled', False)
print(f'Agentic Systems: {\"on\" if enabled else \"off\"}')
" 2>/dev/null
            ;;
    esac
}

cmd_state() {
    local subcmd="${1:-}"
    case "$subcmd" in
        list)
            cli_request "/cli/states/list" | python3 -c "
import json, sys
states = json.loads(sys.stdin.read())
if not states:
    print('No workspace states defined.')
    sys.exit(0)
for s in states:
    built_in = ' [DEFAULT]' if s.get('isBuiltIn') else ''
    hb = 'on' if s.get('heartbeat') else 'off'
    print(f\"  {s['name']}{built_in} (heartbeat: {hb})\")
    caps = []
    for k, label in [('capFeatures','Features'),('capIssues','Issues'),('capCrashes','Crashes'),('capSecurity','Security'),('capAudits','Audits')]:
        caps.append(f'{label}:{s.get(k,\"off\")}')
    print(f'    {\"  \".join(caps)}')
    if s.get('description'):
        print(f'    {s[\"description\"]}')
" 2>/dev/null
            ;;
        get)
            shift
            local id="${1:-}"
            if [ -z "$id" ]; then
                echo "Usage: k2so state get <state-id>" >&2
                exit 1
            fi
            cli_request "/cli/states/get" "id=$(urlencode "$id")"
            ;;
        set)
            shift
            local state_id=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --state) state_id="$2"; shift 2 ;;
                    *) [ -z "$state_id" ] && state_id="$1"; shift ;;
                esac
            done
            if [ -z "$state_id" ]; then
                echo "Usage: k2so state set <state-id>" >&2
                echo "  Assign a workspace state to the current project." >&2
                echo "  Use 'k2so state list' to see available states." >&2
                exit 1
            fi
            cli_request "/cli/states/set" "state_id=$(urlencode "$state_id")"
            echo "Workspace state set to: $state_id"
            ;;
        *)
            echo "Usage: k2so state <list|get|set>" >&2
            exit 1
            ;;
    esac
}

