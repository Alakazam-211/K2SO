cmd_heartbeat_wake() {
    # Automated coordinator wake cycle:
    # 1. Check if any agents have inbox work
    # 2. If coordinator is running → send triage message
    # 3. If coordinator is asleep → launch with triage prompt
    # Check both agent inboxes and workspace inbox for work
    local has_work
    has_work=$(python3 -c "
import json, sys, subprocess, os

port = os.environ.get('K2SO_PORT', '')
token = os.environ.get('K2SO_HOOK_TOKEN', '')
if not port:
    try: port = open(os.path.expanduser('~/.k2so/heartbeat.port')).read().strip()
    except: pass
if not token:
    try: token = open(os.path.expanduser('~/.k2so/heartbeat.token')).read().strip()
    except: pass

project = '$PROJECT'
base = f'http://127.0.0.1:{port}'

agent_inbox = False
ws_inbox = False
try:
    import urllib.request
    req = urllib.request.Request(f'{base}/cli/agents/list?token={token}&project={urllib.parse.quote(project)}')
    with urllib.request.urlopen(req, timeout=5) as resp:
        agents = json.loads(resp.read())
        agent_inbox = any(a.get('inboxCount', 0) > 0 for a in agents)
except: pass
try:
    req = urllib.request.Request(f'{base}/cli/work/inbox?token={token}&project={urllib.parse.quote(project)}')
    with urllib.request.urlopen(req, timeout=5) as resp:
        items = json.loads(resp.read())
        ws_inbox = len(items) > 0 if isinstance(items, list) else False
except: pass

print('yes' if (agent_inbox or ws_inbox) else 'no')
" 2>/dev/null || echo "no")

    if [ "$has_work" != "yes" ]; then
        echo '{"status":"noop","reason":"no inbox work found"}'
        return
    fi

    # Check if coordinator terminal is already running
    local running
    running=$(cli_request "/cli/agents/running" 2>/dev/null)
    local coord_id
    coord_id=$(echo "$running" | python3 -c "
import json, sys
try:
    data = json.loads(sys.stdin.read())
    for t in data:
        cwd = t.get('cwd', '')
        if '.k2so/agents/coordinator' in cwd or t.get('terminalId', '').startswith('agent-chat-coordinator'):
            print(t['terminalId'])
            break
except:
    pass
" 2>/dev/null)

    if [ -n "$coord_id" ]; then
        # Coordinator is awake — send triage message
        local msg="New work detected. Run k2so agents list and delegate any inbox items."
        cli_request "/cli/terminal/write" "id=$(urlencode "$coord_id")&message=$(urlencode "$msg")"
        echo "{\"status\":\"notified\",\"terminalId\":\"$coord_id\"}"
    else
        # Coordinator is asleep — launch it, then send triage message after startup
        cli_request "/cli/agents/launch" "agent=coordinator"
        # Wait for the terminal to be created and Claude to initialize
        local attempts=0
        while [ $attempts -lt 12 ]; do
            sleep 5
            attempts=$((attempts + 1))
            # Check if coordinator terminal now exists
            local check
            check=$(cli_request "/cli/agents/running" 2>/dev/null)
            local new_coord_id
            new_coord_id=$(echo "$check" | python3 -c "
import json, sys
try:
    data = json.loads(sys.stdin.read())
    for t in data:
        cwd = t.get('cwd', '')
        if '.k2so/agents/coordinator' in cwd or t.get('terminalId', '').startswith('agent-chat-coordinator'):
            print(t['terminalId'])
            break
except:
    pass
" 2>/dev/null)
            if [ -n "$new_coord_id" ]; then
                # Terminal exists — send triage message
                local msg="New work detected. Run k2so agents list and delegate any inbox items."
                cli_request "/cli/terminal/write" "id=$(urlencode "$new_coord_id")&message=$(urlencode "$msg")"
                echo "{\"status\":\"launched_and_notified\",\"terminalId\":\"$new_coord_id\"}"
                return
            fi
        done
        echo '{"status":"launched","agent":"coordinator","note":"triage message not sent - terminal not ready"}'
    fi
}

cmd_agent_complete() {
    # Sub-agent completion command:
    # Reads workspace state capability for the work item's source type
    # Auto mode: commit, merge, clean up, notify coordinator
    # Gated mode: commit, move to done, notify coordinator for review
    local agent="" file=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --agent) agent="$2"; shift 2 ;;
            --file)  file="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    if [ -z "$agent" ] || [ -z "$file" ]; then
        echo "Usage: k2so agent complete --agent <name> --file <filename>" >&2
        exit 1
    fi
    cli_request "/cli/agent/complete" "agent=$(urlencode "$agent")&file=$(urlencode "$file")"
}

