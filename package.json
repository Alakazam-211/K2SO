{
  "name": "k2so",
  "version": "0.1.0",
  "description": "Developer workspace with terminal panes, git worktrees, and agent presets",
  "main": "./out/main/index.js",
  "author": "Alakazam Labs",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "package": "electron-vite build && electron-builder --mac --config electron-builder.config.ts",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.config.ts",
    "package:dmg": "electron-vite build && electron-builder --mac dmg --config electron-builder.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.38.0",
    "electron-updater": "^6.3.0",
    "node-pty": "1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-mosaic-component": "^5.3.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.27.0",
    "superjson": "^2.2.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.30.0",
    "electron": "40",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
